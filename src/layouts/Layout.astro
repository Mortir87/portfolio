---
const { title = "Portfolio Aitor Santos" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/logo-as.svg" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html, body {
		background: #0b0b0f;
		color: white;
		margin: 0;
		height: 100%;
		font-family: system-ui, sans-serif;
		scroll-behavior: smooth;
	}

</style>
